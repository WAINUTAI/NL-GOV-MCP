# Optional API keys — most tools work without any keys
KNMI_API_KEY=
OVERHEID_API_KEY=
BAG_API_KEY=

# Transport: stdio (default), sse, or streamable-http
# MCP_TRANSPORT=stdio

# HTTP port for SSE / Streamable HTTP transports
# NL_GOV_HTTP_PORT=3333

# Timezone for natural date parsing (default: Europe/Amsterdam)
# NL_GOV_TIMEZONE=Europe/Amsterdam

# Log level: debug, info, warn, error, silent
# LOG_LEVEL=info
